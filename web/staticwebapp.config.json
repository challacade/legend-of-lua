{
  "globalHeaders": {
    "Cross-Origin-Opener-Policy": "same-origin",
    "Cross-Origin-Embedder-Policy": "require-corp"
  },
  "routes": [
    {
      "route": "/index.html",
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/player.js",
      "headers": {
        "Cache-Control": "no-cache"
      }
    },
    {
      "route": "/legend-of-lua.love",
      "headers": {
        "Cache-Control": "no-cache"
      }
    },
    {
      "route": "/lua/*",
      "headers": {
        "Cache-Control": "no-cache"
      }
    }
  ]
}
